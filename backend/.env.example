# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/webshopac

# JWT Secret Key (thay bằng chuỗi ngẫu nhiên mạnh)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Client URL (để cấu hình CORS)
CLIENT_URL=http://localhost:5173

# Zalo Phone Number (số điện thoại Zalo của admin)
ZALO_PHONE=0900000000

# Node Environment
NODE_ENV=development

# --- PAYOS CONFIGURATION (Nạp tiền tự động qua PayOS - miễn phí) ---
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# --- FALLBACK BANK & VIETQR CONFIGURATION (Cấu hình VietQR khi chưa có PayOS keys) ---
# Tên viết tắt ngân hàng: e.g. MB, VCB, ACB, VietinBank (Tra cứu tại vietqr.io)
BANK_ID=MB
BANK_ACCOUNT=0978264349
BANK_OWNER=NGUYEN TAN DUONG

