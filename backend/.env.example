# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/webshopac

# JWT Secret Key (thay bằng chuỗi ngẫu nhiên mạnh)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Client URL (để cấu hình CORS)
CLIENT_URL=http://localhost:5173

# Zalo Phone Number (số điện thoại Zalo của admin)
ZALO_PHONE=0900000000

# Node Environment
NODE_ENV=development
