# =========================
# Root .gitignore (monorepo)
# =========================

# --- Dependencies ---
**/node_modules/

# --- Build outputs ---
**/dist/
**/dist-ssr/
**/build/

# --- Env / secrets ---
**/.env
**/.env.*
!.env.example
!**/.env.example

# --- Logs ---
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# --- Runtime / cache ---
**/.cache/
**/.parcel-cache/
**/.vite/
**/.turbo/
**/.next/
**/.nuxt/
**/coverage/

# --- OS files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --- Cursor local files ---
.cursor/

